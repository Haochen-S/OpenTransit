# Database (local Docker defaults — change for production deployments)
DATABASE_URL=postgresql://opentransit:opentransit@localhost:5432/opentransit
POSTGRES_USER=opentransit
POSTGRES_PASSWORD=opentransit
POSTGRES_DB=opentransit

# development | production (production disables public API docs and enforces secret checks)
ENVIRONMENT=development

# JWT (required — use a long random string, at least 32 characters)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# TfNSW Open Data API key (server-side only — never expose in frontend)
TFNSW_API_KEY=your-tfnsw-api-key
TFNSW_BASE_URL=https://api.transport.nsw.gov.au/v1/tp

# Comma-separated browser origins allowed to call the API (set your public site URL in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend build (optional — defaults to /api when served behind nginx)
VITE_API_URL=/api

# docker-compose.prod.yml — host port for nginx (default 80)
HTTP_PORT=80

# API rate limiting (per client IP)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_SCHEDULE=90/minute
TRUST_PROXY_HEADERS=true
