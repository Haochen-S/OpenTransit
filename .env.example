# development | production (production disables API docs and enforces secret checks)
ENVIRONMENT=development

# Database — compose overrides DATABASE_URL for the backend container (@db:5432)
POSTGRES_USER=opentransit
POSTGRES_PASSWORD=opentransit
POSTGRES_DB=opentransit
DATABASE_URL=postgresql://opentransit:opentransit@db:5432/opentransit

# JWT — min 32 chars; generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# TfNSW Open Data (backend only — never expose in frontend)
TFNSW_API_KEY=your-tfnsw-api-key
TFNSW_BASE_URL=https://api.transport.nsw.gov.au/v1/tp

# Allowed browser origins (add your EC2/domain URL in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend — /api when served behind nginx
VITE_API_URL=/api

# docker-compose.prod.yml — public web port
HTTP_PORT=80

# Rate limiting (per client IP, behind nginx)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_SCHEDULE=90/minute
TRUST_PROXY_HEADERS=true

# Email OTP login — SMTP required in production; dev without SMTP logs OTP to backend
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_SEND_LIMIT_PER_HOUR=5
CAPTCHA_TTL_SECONDS=300
# Optional separate pepper for OTP hashing (defaults to JWT_SECRET)
# OTP_PEPPER=
